{
  "name": "wired",
  "version": "1.0.0",
  "description": "Web Interface Retro Editor for Desktop (WIRED) — A lightweight WYSIWYG HTML editor",
  "main": "out/main/index.js",
  "author": {
    "name": "Jeremy Riel",
    "email": "jriel2@uic.edu",
